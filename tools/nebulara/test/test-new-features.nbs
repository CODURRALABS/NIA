LET arr = [10, 20, 30]
arr[1] = 99
PRINT(arr[1])
PRINT(arr)

LET a = [1, 2]
LET b = [3, 4]
LET c = a + b
PRINT(LEN(c))
PRINT(c[2])

PUSH(arr, 40)
PRINT(LEN(arr))
PRINT(arr[3])

LET removed = POP(arr)
PRINT(removed)
PRINT(LEN(arr))

PRINT(5 & 3)
PRINT(5 | 3)
PRINT(1 << 3)
PRINT(16 >> 2)

PRINT(ABS(-42))
PRINT(MIN(10, 20))
PRINT(MAX(10, 20))
PRINT(SQRT(16))
PRINT(POW(2, 10))

PRINT(CHAR(65))
PRINT(ORD("Z"))

LET s = "hello"
PRINT(TO_UPPER(s))
PRINT(TO_LOWER(s))
PRINT(CHAR_AT(s, 1))
PRINT(SUBSTR(s, 1, 3))
PRINT(TRIM("  hi  "))
