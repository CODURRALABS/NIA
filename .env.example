# NIA Environment Configuration
# Copy to .env and fill in your API keys
# NEVER commit .env to git

# Hugging Face Hub (free: https://huggingface.co/settings/tokens)
HF_TOKEN=hf_YOUR_TOKEN_HERE

# Kaggle API (free: https://www.kaggle.com/settings)
KAGGLE_API_TOKEN=YOUR_KAGGLE_TOKEN_HERE

# Hardware Optimization
TORCH_NUM_THREADS=4
OMP_NUM_THREADS=4

# Training Defaults
BATCH_SIZE=1
MODEL_PRECISION=bf16
CONTEXT_WINDOW=4096

# Firecrawl Web Scraping (free tier: https://firecrawl.dev)
FIRECRAWL_API_KEY=fc_YOUR_KEY_HERE
FIRECRAWL_BASE_URL=https://api-us1.surfsky.io

# Composio 200+ Tool Integrations (free tier: https://app.composio.dev)
COMPOSIO_API_KEY=ak_YOUR_KEY_HERE

# Free Unlimited LLM Providers (OmniRoute-style)
# iFlow (free, unlimited: https://iflow.cn)
IFLOW_API_KEY=YOUR_IFLOW_KEY_HERE

# Qwen/DashScope (free tier: https://dashscope.aliyun.com)
QWEN_API_KEY=YOUR_QWEN_KEY_HERE

# SiliconFlow (free models: https://siliconflow.cn)
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_KEY_HERE

# NVIDIA NIM (free tier: https://build.nvidia.com)
NVIDIA_API_KEY=nvapi_YOUR_KEY_HERE

# OpenRouter (free models: https://openrouter.ai)
OPENROUTER_API_KEY=sk-or_YOUR_KEY_HERE
